@typeparam TValue
@inherits InputBase<TValue>

<div class="wrapper @(IsFocus && !Disabled ? "focused" : "")">

    @if (Multiline)
    {
        <textarea class="wrapper-input @CssClass"
                  rows="@Rows"
                  placeholder=" "
                  value="@BindConverter.FormatValue(CurrentValue)"
                  minlength="@MinLength"
                  maxlength="@MaxLength"
                  disabled="@Disabled"
                  @oninput="Disabled ? null : OnInputChanged"
                  @onfocus="Disabled ? null : () => IsFocus = true"
                  @onblur="HandleBlur">
        </textarea>
    }
    else
    {
        <input class="wrapper-input @CssClass"
               type="@InputType"
               placeholder=" "
               value="@BindConverter.FormatValue(CurrentValue)"
               minlength="@MinLength"
               maxlength="@MaxLength"
               disabled="@Disabled"
               @oninput="Disabled ? null : OnInputChanged"
               @onfocus="Disabled ? null : () => IsFocus = true"
               @onblur="HandleBlur" />
    }

    <label>@Placeholder</label>

    <div class="right-icons">

        @if (ShowValidationIcon)
        {
            <span class="validation-icon">
                <i class="@ValidationIcon"></i>
            </span>
        }

        @if (IsPassword && !Multiline)
        {
            <button type="button"
                    class="toggle"
                    @onclick="TogglePassword">
                <i class="@IconClass"></i>
            </button>
        }

    </div>
</div>

@code {

    [Parameter]
    public string? Placeholder { get; set; } = "Enter a field value";

    [Parameter]
    public string? Type { get; set; } = "text";

    [Parameter]
    public int? MinLength { get; set; }

    [Parameter]
    public int? MaxLength { get; set; }
    [Parameter]
    public bool Disabled { get; set; }
    [Parameter]
    public bool Multiline { get; set; } = false;

    [Parameter]
    public int Rows { get; set; } = 3;

    private bool IsFocus = false;
    private bool CanShowPassword = false;

    private bool IsPassword => Type?.ToLower() == "password";

    private string? InputType => IsPassword
        ? (CanShowPassword ? "text" : "password")
        : Type;

    private string IconClass => CanShowPassword
        ? "bi bi-eye-slash"
        : "bi bi-eye";

    private void TogglePassword()
        => CanShowPassword = !CanShowPassword;

    private async Task OnInputChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString() ?? "";

        // Enforce MaxLength manually (extra safety)
        if (MaxLength.HasValue && value.Length > MaxLength.Value)
            return;

        if (BindConverter.TryConvertTo<TValue>(value, CultureInfo.CurrentCulture, out var parsedValue))
        {
            CurrentValue = parsedValue;
        }

        await Task.CompletedTask;
    }

    private void HandleBlur(FocusEventArgs e)
    {
        IsFocus = false;
        EditContext?.NotifyFieldChanged(FieldIdentifier);
    }

    private bool HasError =>
        EditContext?.GetValidationMessages(FieldIdentifier).Any() == true;

    private bool HasValidationState =>
        EditContext?.GetValidationMessages(FieldIdentifier).Any() == true ||
        EditContext?.IsModified(FieldIdentifier) == true;

    private bool IsValid =>
        !HasError &&
        CurrentValue != null &&
        !string.IsNullOrWhiteSpace(CurrentValue.ToString());

    private bool ShowValidationIcon =>
        HasValidationState;

    private string CssClass =>
        HasError ? "invalid" :
        IsValid && HasValidationState ? "valid" :
        "";

    private string ValidationIcon =>
        HasError
            ? "bi bi-exclamation-circle-fill text-danger"
            : "bi bi-check-circle-fill text-success";

    protected override bool TryParseValueFromString(string? value, out TValue result, out string validationErrorMessage)
    {
        value ??= "";

        if (MinLength.HasValue && value.Length < MinLength.Value)
        {
            result = default!;
            validationErrorMessage = $"Minimum length is {MinLength.Value}.";
            return false;
        }

        if (MaxLength.HasValue && value.Length > MaxLength.Value)
        {
            result = default!;
            validationErrorMessage = $"Maximum length is {MaxLength.Value}.";
            return false;
        }

        if (BindConverter.TryConvertTo<TValue>(value, CultureInfo.CurrentCulture, out var parsedValue))
        {
            result = parsedValue;
            validationErrorMessage = null;
            return true;
        }

        result = default!;
        validationErrorMessage = $"The {FieldIdentifier.FieldName} field is not valid.";
        return false;
    }
}