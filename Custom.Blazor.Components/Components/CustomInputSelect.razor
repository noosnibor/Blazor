@typeparam TItem
@typeparam TValue
@inherits InputBase<TValue>

<div class="floating-select-wrapper @(IsFloating ? "floating" : "")">

    <select class="form-select @ValidationClass"
            value="@CurrentValueAsString"
            disabled="@Disabled"
            @onchange="HandleChange"
            @onfocus="() => IsFocused = true"
            @onblur="() => IsFocused = false">

        @if (Items != null)
        {
            @foreach (var item in Items)
            {
                var value = ValueSelector(item);
                var key = GetOrCreateKey(value);
                var text = TextSelector(item);

                <option value="@key">@text</option>
            }
        }

    </select>

    <label>@Label</label>

</div>

@code {

    /* ============================= */
    /* PARAMETERS                    */
    /* ============================= */

    [Parameter] public string Label { get; set; }

    [Parameter] public IEnumerable<TItem> Items { get; set; }

    [Parameter] public Func<TItem, TValue> ValueSelector { get; set; }

    [Parameter] public Func<TItem, string> TextSelector { get; set; }

    [Parameter] public bool Disabled { get; set; }

    [Parameter] public EventCallback<TValue> OnSelectedValueChanged { get; set; }

    /* ============================= */
    /* STATE                         */
    /* ============================= */

    private bool IsFocused { get; set; }

    private Dictionary<string, TValue> _lookup = new();
    private Dictionary<TValue, string> _reverseLookup = new();

    /* ============================= */
    /* INITIALIZE LOOKUP             */
    /* ============================= */

    protected override void OnParametersSet()
    {
        _lookup.Clear();
        _reverseLookup.Clear();

        if (Items != null)
        {
            foreach (var item in Items)
            {
                var value = ValueSelector(item);
                GetOrCreateKey(value);
            }
        }
    }

    private string GetOrCreateKey(TValue value)
    {
        if (_reverseLookup.TryGetValue(value, out var existing))
            return existing;

        var key = Guid.NewGuid().ToString();

        _lookup[key] = value;
        _reverseLookup[value] = key;

        return key;
    }

    /* ============================= */
    /* UI STATE                      */
    /* ============================= */

    private bool HasValue =>
        !EqualityComparer<TValue>.Default.Equals(CurrentValue, default);

    private bool IsFloating => IsFocused || HasValue;

    private string ValidationClass =>
        EditContext?.GetValidationMessages(FieldIdentifier).Any() == true
            ? "is-invalid"
            : "";

    /* ============================= */
    /* CHANGE HANDLER                */
    /* ============================= */

    private async Task HandleChange(ChangeEventArgs e)
    {
        var key = e.Value?.ToString();

        if (key != null && _lookup.TryGetValue(key, out var selected))
        {
            CurrentValue = selected;

            if (OnSelectedValueChanged.HasDelegate)
                await OnSelectedValueChanged.InvokeAsync(selected);
        }
    }

    /* ============================= */
    /* STARTUP VALUE SUPPORT         */
    /* ============================= */

    protected override string FormatValueAsString(TValue value)
    {
        if (value != null && _reverseLookup.TryGetValue(value, out var key))
        {
            return key;
        }

        return string.Empty;
    }

    /* ============================= */
    /* PARSE VALUE                   */
    /* ============================= */

    protected override bool TryParseValueFromString(string value, out TValue result, out string validationErrorMessage)
    {
        if (_lookup.TryGetValue(value, out var selected))
        {
            result = selected;
            validationErrorMessage = null;
            return true;
        }

        result = default;
        validationErrorMessage = "Invalid selection.";
        return false;
    }
}